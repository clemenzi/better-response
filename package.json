{
  "name": "better-response",
  "version": "1.0.3",
  "description": "A tiny helper for creating better Fetch API Response objects.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vclemenzi/better-response.git"
  },
  "keywords": [
    "response",
    "fetch",
    "http"
  ],
  "author": "Valerio Clemenzi",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.3.3",
    "tsup": "^8.2.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
